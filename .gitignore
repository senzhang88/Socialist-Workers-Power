# =============================================================================
# 劳动者力量 / WorkPowers 仓库 .gitignore
#
# 公开范围（要 commit 的）：
#   - docs/                 网站源 markdown
#   - mkdocs.yml / overrides / requirements.txt   构建配置
#   - skill/                Claude Skill 源（公开发布）
#   - 法律依据/             法律法规知识基础设施（公开来源、官方原文）
#   - references/           公开整理的案例/法条速查（注：内含个人材料的子目录请单独排除）
#   - resources/            通用资源
#   - opc入住/评审材料/*.md  已在 commit ac8aeec 公开的评审材料
#   - README / LICENSE / CONTRIBUTING / CHANGELOG / DEPLOY / SERVER（去敏后）
#
# 屏蔽范围（绝对不 commit 的）：
#   - 创始人个人维权材料（仲裁/起诉/期权/名誉权等案件原始档案）
#   - 服务器访问凭据 / 密钥 / 部署敏感信息
#   - 大体积下载产物（裁判文书原始 HTML 等）
#   - 各类编辑器/AI 工具的本地配置目录
#   - 个人 OPC 申请表、政策摘录等私有材料
# =============================================================================

# -----------------------------------------------------------------------------
# OS / 编辑器通用
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# -----------------------------------------------------------------------------
# Claude / AI 工具本地配置（不能开源，含本地状态、API 历史等）
# -----------------------------------------------------------------------------
.claude/
.agents/
.codebuddy/
.continue/
.iflow/
.kiro/
.omc/
.qoder/
.qwen/
.trae/
.windsurf/
.gstack/
.cache/

# -----------------------------------------------------------------------------
# 个人维权案件档案（绝对私有 - 含真实姓名、判决书、合同等敏感材料）
# -----------------------------------------------------------------------------
private/
仲裁加投诉/
多方压力/
我的劳动维权案例-个人详细档案/
文书蒸馏/
期权争议/
民事自诉诽谤造谣/
项目总控/

# -----------------------------------------------------------------------------
# OPC 入驻申请的私有材料（已公开评审材料 markdown 已在 commit ac8aeec 提交）
# 屏蔽：政策手册原文、申请表 docx、本地 OMC 状态
# -----------------------------------------------------------------------------
opc入住/*.docx
opc入住/*.md
opc入住/评审材料/*.docx
opc入住/评审材料/.omc/

# -----------------------------------------------------------------------------
# 服务器 / 部署敏感信息
# -----------------------------------------------------------------------------
SERVER_ACCESS.md
*.key
*.pem
*.crt
*.pub
id_rsa*
id_ed25519*
oracle_oci*
config.yaml
config.yml
secrets*
.env*

# -----------------------------------------------------------------------------
# 站点验证占位（生成后只放服务器，不入仓库）
# -----------------------------------------------------------------------------
baidu_verify_*.html

# -----------------------------------------------------------------------------
# 大体积下载产物（爬取的判例 HTML 等，可重新生成，不进仓库）
# -----------------------------------------------------------------------------
wenshu_downloads/

# -----------------------------------------------------------------------------
# 工具锁文件 / 实施计划草稿（本地过程产物，不必公开）
# -----------------------------------------------------------------------------
skills-lock.json
plans/

# -----------------------------------------------------------------------------
# MkDocs 构建产物
# -----------------------------------------------------------------------------
site/
site-*.tar.gz

# -----------------------------------------------------------------------------
# Python / Node 通用
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
.venv/
venv/
node_modules/
